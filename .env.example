# negaverse LLM controller credentials — copy to .env and fill in.
#   cp .env.example .env
# .env is gitignored; this example file is committed. The controller reads
# whichever key matches the selected provider (--provider anthropic|openrouter).

# Anthropic API (default provider). Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (OpenAI-compatible). Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
